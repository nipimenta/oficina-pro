@startuml casos_de_uso
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor #FFFFFF
title Diagrama de Casos de Uso - Sistema OficinaPro

actor "Cliente" as cliente
actor "Atendente" as atendente
actor "Mecânico" as mecanico
actor "Gerente" as gerente

rectangle "Sistema OficinaPro" {
  usecase "UC-01\nAgendar Serviço" as UC01
  usecase "UC-02\nAbrir Ordem de Serviço" as UC02
  usecase "UC-03\nElaborar Orçamento" as UC03
  usecase "UC-04\nRegistrar Execução\nde Serviço" as UC04
  usecase "UC-05\nEfetuar Pagamento" as UC05
  usecase "UC-06\nGerenciar Estoque\nde Peças" as UC06
  usecase "UC-07\nEmitir Relatórios\nGerenciais" as UC07
  usecase "Aprovar\nOrçamento" as UCAprov
}

cliente --> UC01
cliente --> UCAprov
atendente --> UC02
atendente --> UC03
atendente --> UC05
mecanico --> UC04
mecanico --> UC06
gerente --> UC06
gerente --> UC07

UC03 ..> UC02 : <<include>>
UC04 ..> UC02 : <<include>>
UC03 ..> UCAprov : <<extend>>
UC05 ..> UC04 : <<include>>
@enduml
